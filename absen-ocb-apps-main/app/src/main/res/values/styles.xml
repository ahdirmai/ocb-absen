<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/spinner_background</item> <!-- Background drawable -->
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:textColor">@color/black</item> <!-- Warna teks -->
        <item name="android:textSize">16sp</item> <!-- Ukuran teks -->
        <item name="android:popupBackground">@drawable/spinner_dropdown_background</item> <!-- Background dropdown -->
    </style>

</resources>